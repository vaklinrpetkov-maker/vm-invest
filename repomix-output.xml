            }}
            className="grid grid-cols-1 md:grid-cols-[1fr_1fr_auto] gap-3 items-end pt-3 border-t border-neutral-100"
          >
            <input type="hidden" name="startIso" value={b.start} />
            <input type="hidden" name="endIso" value={b.end} />
            <div>
              <label
                htmlFor="dayType"
