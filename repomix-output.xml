import Link from "next/link";
import type { Route } from "next";
import { notFound } from "next/navigation";
import { requireProfile } from "@/lib/auth/session";
import { prisma } from "@/lib/prisma";
import { canCreateRenovation } from "@/lib/renovations/permissions";
import { RENOVATION_STATUS_DEFAULT } from "@/lib/renovations/constants";
import { listDistinctRenovationTypes } from "@/lib/renovations/queries";
import {
  RenovationForm,
  type RenovationFormInitial,
} from "../renovation-form";
import { createRenovation } from "../actions";

export const dynamic = "force-dynamic";

// Two entry points per spec §5.2:
//   1. From `/renovations` → blank form.
//   2. From `/properties/[id]` → `?propertyId=…` query param; the form is
//      pre-filled with that property + the property's current owner
//      (Contact.owner) as `requestedByContact`. Saves an admin a typeahead
//      dance when adding work for a known unit.
//
// Pre-fill is best-effort: if the property doesn't exist or has no owner,
// the field stays empty. The server action still re-validates everything.

export default async function NewRenovationPage({
  searchParams,
}: {
  searchParams: Promise<{ propertyId?: string }>;
}) {
  const me = await requireProfile();
  if (!canCreateRenovation(me.role)) notFound();

  const params = await searchParams;
  const propertyId =
    typeof params.propertyId === "string" && params.propertyId.length > 0
      ? params.propertyId
      : null;

  // Pre-fill: look up the property + its owner contact for the "requestedBy"
  // field. Wrapped in a single query so the page renders fast.
  const prefill = propertyId
    ? await prisma.property.findUnique({
        where: { id: propertyId },
        select: {
          id: true,
          name: true,
          entrance: true,
          floor: true,
          status: true,
          type: true,
          building: { select: { displayName: true } },
          owner: {
            select: {
              id: true,
              fullName: true,
              phone: true,
              email: true,
            },
          },
        },
      })
    : null;

  const types = await listDistinctRenovationTypes();

  const initial: RenovationFormInitial = {
    title: prefill ? `Ремонт — ${prefill.building.displayName} · ${prefill.name}` : "",
    type: "",
    status: RENOVATION_STATUS_DEFAULT,
    description: "",
    property: prefill
      ? {
          id: prefill.id,
          name: prefill.name,
          buildingDisplayName: prefill.building.displayName,
          entrance: prefill.entrance,
          floor: prefill.floor,
          status: prefill.status,
          type: prefill.type,
        }
      : null,
    requestedBy: prefill?.owner
      ? {
          id: prefill.owner.id,
          fullName: prefill.owner.fullName,
          phone: prefill.owner.phone,
          email: prefill.owner.email,
        }
      : null,
    // Manager defaults to the creator on the server side; leave empty in the
    // form so the user sees they can override it.
    manager: null,
    plannedStartDate: "",
    plannedEndDate: "",
    actualStartDate: "",
    actualEndDate: "",
  };

  return (
    <div className="space-y-6">
      <div>
        <Link
          href={"/renovations" as Route}
          className="text-sm text-neutral-500 hover:text-neutral-900"
        >
          ← Назад към Ремонти
        </Link>
        <h1 className="text-xl text-neutral-900 mt-1">Нов ремонт</h1>
        <p className="text-base text-neutral-600">
          Опишете обхвата и графика. Задачите се добавят след създаване, на
          страницата на ремонта.
        </p>
      </div>

      <RenovationForm
        action={createRenovation}
        initial={initial}
        submitLabel="Създай ремонт"
        pendingLabel="Създаване…"
        mode="create"
        typeSuggestions={types}
      />
    </div>
  );
}
</file>

