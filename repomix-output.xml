            </DetailRow>
            <DetailRow label="Платено">
              <span className="tabular-nums text-success-700">
                {fmtMoney(c.totalPaidEur)}
              </span>
            </DetailRow>
            <DetailRow label="Остава">
              <span
                className={cn(
                  "tabular-nums font-medium",
                  Number(c.totalRemainingEur) > 0.01
                    ? "text-warning-800"
