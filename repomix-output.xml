<file path="app/(app)/contracts/attachment-actions.ts">
"use server";

// Server actions for contract attachments. The upload action receives a
// FormData with `contractId` + `file` (single file at a time — the cell's
// loop iterates client-side). The delete action takes an attachment id.
//
// Permission model (per specs/contracts.md §8):
//   - upload: any signed-in profile (admin/manager/user).
//   - delete: admin only — deletion is destructive and the spec restricts
//     file deletion to admins because attachments are part of a legal record.
//
// Storage layout: `contracts/{contractId}/{attachmentId}.{ext}` — purely
// ASCII so Supabase Storage accepts the key regardless of the file's
// original name. The human-friendly filename (Cyrillic included) lives in
// the `fileName` column and is surfaced through `Content-Disposition` on
// signed download URLs (see app/api/files/sign/route.ts).

import { randomUUID } from "node:crypto";
import { headers } from "next/headers";
import { revalidatePath } from "next/cache";
import { recordAuditEvent } from "@/lib/auth/audit";
import { requireProfile, requireRole } from "@/lib/auth/session";
import { prisma } from "@/lib/prisma";
import { deleteFile, ensureBucketExists, uploadFile } from "@/lib/supabase/storage";

const UUID_RE =
  /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

// Per spec — upload cap. Bigger than any legitimate construction
// contract PDF; rejects accidental video/installer uploads.
const MAX_UPLOAD_BYTES = 25 * 1024 * 1024;

const CONTRACTS_BUCKET = "contracts";

// Characters never allowed in the DB-side display filename: ASCII control
// chars (0x00-0x1F) and the Windows-invalid path-character set. Cyrillic,
// Latin letters, digits, spaces, dashes, dots all pass through.
const DB_UNSAFE_CHARS = /[␀-<>:"/\\|?*]+/g;
const WHITESPACE = /\s+/g;

// Whitelist for ASCII extensions used in the storage key. Anything else
// falls back to `.bin` — we keep the key structurally clean and trust the
// MIME type stored in the DB for content negotiation.
const SAFE_EXT_RE = /^[a-z0-9]{1,16}$/;

export type UploadResult =
  | { ok: true; attachmentId: string }
  | { ok: false; error: string };

export type DeleteResult = { ok: true } | { ok: false; error: string };

export async function uploadContractAttachment(
  formData: FormData,
): Promise<UploadResult> {
  const actor = await requireProfile();

  const contractId = String(formData.get("contractId") ?? "");
  if (!UUID_RE.test(contractId)) {
    return { ok: false, error: "Невалиден договор." };
  }

  const file = formData.get("file");
  if (!(file instanceof Blob) || file.size === 0) {
    return { ok: false, error: "Не е избран файл." };
  }
  if (file.size > MAX_UPLOAD_BYTES) {
    return {
      ok: false,
      error: `Файлът надвишава лимита (${Math.round(MAX_UPLOAD_BYTES / 1024 / 1024)} МБ).`,
    };
  }

  const contract = await prisma.contract.findUnique({
    where: { id: contractId },
    select: { id: true },
  });
  if (!contract) {
    return { ok: false, error: "Договорът не съществува." };
  }

  // Pre-allocate the attachment id. We use it for both the DB row and the
  // storage key, so the two stay in sync without a separate identifier.
  const attachmentId = randomUUID();
  const rawName =
    "name" in file && typeof (file as File).name === "string"
      ? (file as File).name
      : "";
  // `fileName` is the human-readable name persisted to the DB. Keeps
  // Cyrillic + spaces; only strips path separators and control characters.
  const fileName = sanitizeDisplayFileName(rawName);
  // Storage key is purely structural — ASCII-only so Supabase Storage
  // accepts it regardless of the original filename. The extension is
  // preserved when it's a clean ASCII token (pdf, docx, jpg, …);
  // otherwise we fall back to `.bin` and rely on the `mimeType` column.
  const ext = extractAsciiExtension(rawName);
  const storageKey = `${CONTRACTS_BUCKET}/${contractId}/${attachmentId}${ext}`;
  // The browser-supplied MIME may be missing or generic; fall back to octet-stream.
  const mimeType =
    "type" in file && typeof file.type === "string" && file.type !== ""
      ? file.type
      : "application/octet-stream";

  // Make sure the bucket exists. ensureBucketExists is idempotent so this
  // is safe to call on every upload — costs one extra round-trip but keeps
  // setup zero-touch.
  const bucketReady = await ensureBucketExists(CONTRACTS_BUCKET);
  if (!bucketReady) {
    return { ok: false, error: "Системата за съхранение на файлове не е достъпна." };
  }

  const buf = Buffer.from(await file.arrayBuffer());
  const uploadResult = await uploadFile(storageKey, buf, { contentType: mimeType });
  if (!uploadResult.ok) {
    return {
      ok: false,
      error: `Качването не успя: ${uploadResult.error}`,
    };
  }

  let createdId: string;
  try {
    const created = await prisma.contractAttachment.create({
      data: {
        id: attachmentId,
        contractId,
        type: "other",
        fileName,
        storageKey,
        mimeType,
        sizeBytes: file.size,
        version: 1,
        uploadedById: actor.id,
      },
      select: { id: true },
    });
    createdId = created.id;
  } catch (err) {
    // Roll back the storage upload — we don't want orphans in the bucket.
    await deleteFile(storageKey);
    console.error("[attachments] db insert failed", err);
    return { ok: false, error: "Записът в базата не успя." };
  }

  const hdrs = await headers();
  await recordAuditEvent({
    actorId: actor.id,
    action: "contracts.attachment.uploaded",
    targetType: "attachment",
    targetId: createdId,
    payload: { contractId, fileName, sizeBytes: file.size, mimeType },
    ip: hdrs.get("x-forwarded-for") ?? null,
    userAgent: hdrs.get("user-agent") ?? null,
  });

  revalidatePath("/contracts");
  revalidatePath(`/contracts/${contractId}`);

  return { ok: true, attachmentId: createdId };
}

export async function deleteContractAttachment(
  attachmentId: string,
): Promise<DeleteResult> {
  const actor = await requireRole("admin");

  if (!UUID_RE.test(attachmentId)) {
    return { ok: false, error: "Невалиден файл." };
  }

  const row = await prisma.contractAttachment.findUnique({
    where: { id: attachmentId },
    select: { id: true, contractId: true, fileName: true, storageKey: true },
  });
  if (!row) return { ok: false, error: "Файлът не е намерен." };

  // Best-effort: storage first, then DB. If storage delete fails we still
  // try the DB — orphaned storage objects are recoverable; orphaned DB
  // rows produce confusing 404s on the next signing request.
  await deleteFile(row.storageKey);
  await prisma.contractAttachment.delete({ where: { id: row.id } });

  const hdrs = await headers();
  await recordAuditEvent({
    actorId: actor.id,
    action: "contracts.attachment.deleted",
    targetType: "attachment",
    targetId: attachmentId,
    payload: { contractId: row.contractId, fileName: row.fileName },
    ip: hdrs.get("x-forwarded-for") ?? null,
    userAgent: hdrs.get("user-agent") ?? null,
  });

  revalidatePath("/contracts");
  revalidatePath(`/contracts/${row.contractId}`);

  return { ok: true };
}

// Sanitize the filename we save to the DB + echo back in
// Content-Disposition. Cyrillic preserved; only path-unsafe + control
// characters stripped, repeated whitespace collapsed, length capped.
function sanitizeDisplayFileName(name: string): string {
  const trimmed = name.trim().slice(0, 200);
  const noUnsafe = trimmed.replace(DB_UNSAFE_CHARS, "_");
  const collapsed = noUnsafe.replace(WHITESPACE, " ").trim();
  return collapsed.length > 0 ? collapsed : "файл";
}

// Pull the file extension out as a clean ASCII suffix. Returns ".pdf",
// ".docx", etc., or ".bin" if the extension is missing / non-ASCII / too
// long. The leading dot is included in the return value so it can be
// concatenated directly into the storage key.
function extractAsciiExtension(name: string): string {
  const lastDot = name.lastIndexOf(".");
  if (lastDot < 0 || lastDot === name.length - 1) return ".bin";
  const ext = name.slice(lastDot + 1).toLowerCase();
  return SAFE_EXT_RE.test(ext) ? `.${ext}` : ".bin";
}
