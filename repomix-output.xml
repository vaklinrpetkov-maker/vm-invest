"use client";

import { useActionState, useState } from "react";
import { Button } from "@/components/ui/button";
import { ContactPicker } from "@/components/ui/contact-picker";
import { Input } from "@/components/ui/input";
import { PropertyPicker } from "@/components/ui/property-picker";
import { UserPicker } from "@/components/ui/user-picker";
import type { ContactSuggestion } from "@/lib/contacts/search";
import type { ProfileSuggestion } from "@/lib/profiles/search";
import type { PropertySuggestion } from "@/lib/properties/search";
import {
  RENOVATION_STATUSES,
  RENOVATION_STATUS_LABELS,
} from "@/lib/renovations/constants";
import type { RenovationFormState } from "@/lib/renovations/parse";
import type { RenovationStatus } from "@prisma/client";

// Shared form for create + edit. The parent page binds the action and
// supplies initial values + `mode`. On successful create the action returns
// `createdRenovationId` and we navigate via window.location (server-side
// redirect mid-action breaks the useActionState contract).

export type RenovationFormInitial = {
  title: string;
  type: string;
  status: RenovationStatus;
  description: string;
  property: PropertySuggestion | null;
  requestedBy: ContactSuggestion | null;
  manager: ProfileSuggestion | null;
  plannedStartDate: string; // ISO YYYY-MM-DD
  plannedEndDate: string;
  actualStartDate: string;
  actualEndDate: string;
};

type Props = {
  action: (
    prev: RenovationFormState,
    formData: FormData,
  ) => Promise<RenovationFormState>;
  initial: RenovationFormInitial;
  submitLabel: string;
  pendingLabel: string;
  mode: "create" | "edit";
  // Available type suggestions from existing distinct values — fed into
  // the <datalist> for autocomplete + nudges toward canonical names.
  typeSuggestions: readonly string[];
};

export function RenovationForm({
  action,
  initial,
  submitLabel,
  pendingLabel,
  mode,
  typeSuggestions,
}: Props) {
  const [state, formAction, pending] = useActionState<
    RenovationFormState,
    FormData
  >(action, {});

  const [title, setTitle] = useState(initial.title);
  const [type, setType] = useState(initial.type);
  const [status, setStatus] = useState<RenovationStatus>(initial.status);
  const [description, setDescription] = useState(initial.description);

  // Once a create succeeds, the action returns the new id — navigate.
  if (mode === "create" && state.createdRenovationId) {
    if (typeof window !== "undefined") {
      window.location.href = `/renovations/${state.createdRenovationId}`;
    }
  }

  const fieldError = (key: keyof NonNullable<RenovationFormState["errors"]>) =>
    state.errors?.[key];

  return (
    <form action={formAction} className="space-y-6 max-w-3xl">
      {state.errors?.form && (
        <div className="rounded-lg bg-danger-50 text-danger-700 px-3 py-2 text-sm">
          {state.errors.form}
        </div>
      )}

      <section className="space-y-4">
        <div className="space-y-1.5">
          <label className="text-sm text-neutral-600">Имот *</label>
          <PropertyPicker name="propertyId" initial={initial.property} required />
          {fieldError("propertyId") && (
            <div className="text-sm text-danger-700">{fieldError("propertyId")}</div>
          )}
        </div>

        <div className="space-y-1.5">
          <label className="text-sm text-neutral-600">Заглавие *</label>
          <Input
            name="title"
            value={title}
            onChange={(e) => setTitle(e.target.value)}
            placeholder="напр. Боядисване на хол + кухня"
            maxLength={200}
            required
          />
          {fieldError("title") && (
            <div className="text-sm text-danger-700">{fieldError("title")}</div>
          )}
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">Тип</label>
            <Input
              name="type"
              value={type}
              onChange={(e) => setType(e.target.value)}
              list="renovation-type-suggestions"
              placeholder="напр. Боядисване"
              maxLength={100}
            />
            <datalist id="renovation-type-suggestions">
              {typeSuggestions.map((t) => (
                <option key={t} value={t} />
              ))}
            </datalist>
            {fieldError("type") && (
              <div className="text-sm text-danger-700">{fieldError("type")}</div>
            )}
          </div>

          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">Статус</label>
            <select
              name="status"
              value={status}
              onChange={(e) => setStatus(e.target.value as RenovationStatus)}
              className="block w-full px-3 py-2 rounded-lg bg-neutral-100 text-base text-neutral-900 focus:outline-none focus:ring-2 focus:ring-accent-500/40"
            >
              {RENOVATION_STATUSES.map((s) => (
                <option key={s} value={s}>
                  {RENOVATION_STATUS_LABELS[s]}
                </option>
              ))}
            </select>
          </div>
        </div>

        <div className="space-y-1.5">
          <label className="text-sm text-neutral-600">Описание</label>
          <textarea
            name="description"
            value={description}
            onChange={(e) => setDescription(e.target.value)}
            rows={4}
            maxLength={4000}
            placeholder="Какво трябва да се направи, особени изисквания, контекст…"
            className="block w-full px-3 py-2 rounded-lg bg-neutral-100 text-base text-neutral-900 placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-accent-500/40 resize-y"
          />
          {fieldError("description") && (
            <div className="text-sm text-danger-700">{fieldError("description")}</div>
          )}
        </div>
      </section>

      <section className="space-y-4 border-t border-neutral-150 pt-6">
        <h2 className="text-md font-medium text-neutral-900">Хора</h2>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">
              Заявител <span className="text-neutral-400 text-xs">— ако клиент е заявил ремонта</span>
            </label>
            <ContactPicker
              name="requestedByContactId"
              initial={initial.requestedBy}
              placeholder="Търси контакт…"
            />
          </div>
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">Отговорник</label>
            <UserPicker
              name="managerId"
              initial={initial.manager}
              placeholder="Търси служител…"
            />
          </div>
        </div>
      </section>

      <section className="space-y-4 border-t border-neutral-150 pt-6">
        <h2 className="text-md font-medium text-neutral-900">График</h2>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">Планирано начало</label>
            <Input
              type="date"
              name="plannedStartDate"
              defaultValue={initial.plannedStartDate}
            />
          </div>
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">Планиран край</label>
            <Input
              type="date"
              name="plannedEndDate"
              defaultValue={initial.plannedEndDate}
            />
            {state.warnings?.plannedEndDate && (
              <div className="text-sm text-warning-700">{state.warnings.plannedEndDate}</div>
            )}
          </div>
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">
              Реално начало{" "}
              <span className="text-neutral-400 text-xs">— попълва се автоматично при „В процес“</span>
            </label>
            <Input
              type="date"
              name="actualStartDate"
              defaultValue={initial.actualStartDate}
            />
          </div>
          <div className="space-y-1.5">
            <label className="text-sm text-neutral-600">
              Реално завършване{" "}
              <span className="text-neutral-400 text-xs">— попълва се автоматично при „Завършена“</span>
            </label>
            <Input
              type="date"
              name="actualEndDate"
              defaultValue={initial.actualEndDate}
            />
            {state.warnings?.actualEndDate && (
              <div className="text-sm text-warning-700">{state.warnings.actualEndDate}</div>
            )}
          </div>
        </div>
      </section>

      <div className="flex items-center gap-2 pt-2">
        <Button type="submit" disabled={pending}>
          {pending ? pendingLabel : submitLabel}
        </Button>
      </div>
    </form>
  );
}
</file>

<file path="app/(app)/renovations/renovations-table.tsx">
"use client";

import Link from "next/link";
import type { Route } from "next";
import type { RenovationStatus } from "@prisma/client";
import { ReadOnlyBadge } from "@/components/ui/read-only-badge";
import {
  InlineStatusCell,
  type StatusOption,
} from "@/components/ui/inline-status-cell";
import { Table, TBody, THead, TH, TR, TD, TableEmpty } from "@/components/ui/table";
import {
  RENOVATION_STATUSES,
  RENOVATION_STATUS_LABELS,
  RENOVATION_STATUS_TONES,
} from "@/lib/renovations/constants";
import { setRenovationStatus } from "./actions";

// List-view table for /renovations. Round 1: inline status edit; the other
// columns are display-only. Manager + dates become inline-editable in
// Round 2 once the per-field actions land.

export type RenovationListRowVm = {
  id: string;
  title: string;
  type: string | null;
  status: RenovationStatus;
  propertyId: string;
  propertyName: string;
  propertyBuilding: string;
  managerId: string | null;
  managerName: string | null;
  managerActive: boolean | null;
  requestedByContactId: string | null;
  requestedByContactName: string | null;
  periodLabel: string;
  // ISO strings (`YYYY-MM-DD`) carried separately so the portfolio Gantt
  // can re-hydrate the Date without parsing the display-formatted period.
  plannedStartIso: string | null;
  plannedEndIso: string | null;
  taskTotal: number;
  taskDone: number;
  createdAtFormatted: string;
};

const STATUS_OPTIONS: ReadonlyArray<StatusOption<RenovationStatus>> =
  RENOVATION_STATUSES.map((value) => ({
    value,
    label: RENOVATION_STATUS_LABELS[value],
    tone: RENOVATION_STATUS_TONES[value],
  }));

export function RenovationsTable({ rows }: { rows: RenovationListRowVm[] }) {
  return (
    <Table>
      <THead>
        <TR hover={false}>
          <TH>Заглавие</TH>
          <TH>Имот</TH>
          <TH>Тип</TH>
          <TH>Статус</TH>
          <TH>Отговорник</TH>
          <TH>Период</TH>
          <TH align="right">Прогрес</TH>
          <TH align="right">Създаден</TH>
        </TR>
      </THead>
      <TBody>
        {rows.length === 0 && (
          <TableEmpty colSpan={8}>Няма намерени ремонти.</TableEmpty>
        )}
        {rows.map((r) => {
          const pct = r.taskTotal === 0 ? 0 : Math.round((r.taskDone / r.taskTotal) * 100);
          return (
            <TR key={r.id}>
              <TD>
                <Link
                  href={`/renovations/${r.id}` as Route}
                  className="text-neutral-900 hover:text-accent-700 transition-colors duration-120"
                >
                  {r.title}
                </Link>
              </TD>
              <TD muted className="text-sm">
                <Link
                  href={`/properties/${r.propertyId}` as Route}
                  className="hover:text-accent-700 transition-colors duration-120"
                >
                  {r.propertyBuilding} · {r.propertyName}
                </Link>
              </TD>
              <TD muted className="text-sm">
