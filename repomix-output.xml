// Canonical Bulgarian strings + tone mappings for renovation + task statuses.
// Per `specs/renovations.md` §3.2 + §3.5.

export const RENOVATION_STATUSES: ReadonlyArray<RenovationStatus> = [
  "draft",
  "quoted",
  "approved",
  "in_progress",
  "done",
  "cancelled",
];

