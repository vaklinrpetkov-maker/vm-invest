import {
  addRenovationTask,
  deleteRenovationTask,
  setRenovationTaskAssignee,
  setRenovationTaskEndDate,
  setRenovationTaskStartDate,
  setRenovationTaskStatus,
  setRenovationTaskTitle,
} from "../actions";

export type TaskRowVm = {
  id: string;
  title: string;
  description: string | null;
  status: RenovationTaskStatus;
  startDateIso: string | null;
  endDateIso: string | null;
  assignee: { id: string; fullName: string; active: boolean } | null;
  canEditThisTask: boolean;
};

type Props = {
  renovationId: string;
  tasks: TaskRowVm[];
  assigneeOptions: PersonOption[];
  canDelete: boolean;
  // `adding` is owned by the parent so the "+ Добави задача" button + the
  // inline add-row stay in sync across the list / Gantt toggle. When the
  // parent has the create button hidden (canCreate false), it also leaves
  // this prop as false.
  adding: boolean;
  onCloseAdd: () => void;
};

const STATUS_OPTIONS: ReadonlyArray<StatusOption<RenovationTaskStatus>> =
  RENOVATION_TASK_STATUSES.map((value) => ({
    value,
    label: RENOVATION_TASK_STATUS_LABELS[value],
    tone: RENOVATION_TASK_STATUS_TONES[value],
  }));

export function RenovationTasksEditor({
  renovationId,
  tasks,
  assigneeOptions,
  canDelete,
  adding,
  onCloseAdd,
}: Props) {
  if (tasks.length === 0 && !adding) {
    return (
      <p className="text-sm text-neutral-500">
        Все още няма задачи. Натиснете „+ Добави задача“, за да започнете.
      </p>
    );
  }

  return (
    <Table>
      <THead>
        <TR hover={false}>
          <TH>Заглавие</TH>
          <TH>Изпълнител</TH>
          <TH>Начало</TH>
          <TH>Край</TH>
          <TH>Статус</TH>
          <TH align="right" className="w-16">
            {/* actions column */}
          </TH>
        </TR>
      </THead>
      <TBody>
        {tasks.map((t) => (
          <TaskRow
            key={t.id}
            task={t}
            assigneeOptions={assigneeOptions}
            canDelete={canDelete}
          />
        ))}
        {adding && (
          <AddTaskRow renovationId={renovationId} onDone={onCloseAdd} />
        )}
      </TBody>
    </Table>
  );
}

function TaskRow({
  task,
  assigneeOptions,
  canDelete,
}: {
  task: TaskRowVm;
  assigneeOptions: PersonOption[];
  canDelete: boolean;
}) {
  const [pending, startTransition] = useTransition();
  const disabled = !task.canEditThisTask;

  const onDelete = () => {
    if (!confirm(`Изтриване на задача „${task.title}“?`)) return;
    startTransition(async () => {
      await deleteRenovationTask(task.id);
    });
  };

  return (
    <TR>
      <TD>
        <InlineTextCell
          value={task.title}
          onSave={(v) => setRenovationTaskTitle(task.id, v)}
          maxLength={200}
          disabled={disabled}
        />
      </TD>
      <TD>
        <InlinePersonCell
          value={
            task.assignee
              ? { id: task.assignee.id, fullName: task.assignee.fullName }
              : null
          }
          valueActive={task.assignee?.active ?? true}
          options={assigneeOptions}
          onSave={(newId) => setRenovationTaskAssignee(task.id, newId)}
          emptyLabel="— Не е назначен"
          disabled={disabled}
        />
      </TD>
      <TD muted className="text-sm">
        <InlineDateCell
          value={task.startDateIso}
          onSave={(iso) => setRenovationTaskStartDate(task.id, iso)}
          disabled={disabled}
        />
      </TD>
      <TD muted className="text-sm">
        <InlineDateCell
          value={task.endDateIso}
          onSave={(iso) => setRenovationTaskEndDate(task.id, iso)}
          disabled={disabled}
        />
      </TD>
      <TD>
        <InlineStatusCell
          value={task.status}
          options={STATUS_OPTIONS}
          onSave={(next) => setRenovationTaskStatus(task.id, next)}
          disabled={disabled}
        />
      </TD>
      <TD align="right">
        {canDelete && (
          <button
            type="button"
            onClick={onDelete}
            disabled={pending}
            className={cn(
              "text-sm text-neutral-400 hover:text-danger-700 transition-colors duration-120",
              pending && "opacity-50",
            )}
            aria-label="Изтрий задачата"
          >
            ×
          </button>
        )}
      </TD>
    </TR>
  );
}

function AddTaskRow({
  renovationId,
  onDone,
}: {
  renovationId: string;
  onDone: () => void;
}) {
  const [title, setTitle] = useState("");
  const [error, setError] = useState<string | null>(null);
  const [pending, startTransition] = useTransition();

  const submit = () => {
    if (title.trim().length === 0) return;
    const fd = new FormData();
    fd.set("title", title);
    setError(null);
    startTransition(async () => {
      const result = await addRenovationTask(renovationId, fd);
      if (!result.ok) {
        setError(result.error);
        return;
      }
      setTitle("");
      onDone();
    });
  };

  return (
    <TR hover={false} className="bg-accent-50/30">
      <TD colSpan={6}>
        <div className="flex items-center gap-2">
          <Input
            value={title}
            onChange={(e) => setTitle(e.target.value)}
            onKeyDown={(e) => {
              if (e.key === "Enter") {
                e.preventDefault();
                submit();
              } else if (e.key === "Escape") {
                onDone();
              }
            }}
            placeholder="Заглавие на новата задача — Enter за запазване, Esc за отказ"
            autoFocus
            maxLength={200}
            className="flex-1"
          />
          <Button
            size="sm"
            disabled={pending || title.trim().length === 0}
            onClick={submit}
          >
            {pending ? "Запазване…" : "Запази"}
          </Button>
          <Button variant="ghost" size="sm" onClick={onDone}>
            Отказ
          </Button>
        </div>
        {error && (
          <div className="text-sm text-danger-700 mt-1">{error}</div>
        )}
      </TD>
    </TR>
  );
}
</file>

<file path="app/(app)/renovations/[id]/tasks-section.tsx">
"use client";

// Section chrome for the tasks block on the renovation detail page: title +
// progress + tab toggle (Списък / Гант) + "+ Добави задача" button. The
// underlying inline editor + Gantt chart are wired below.
//
// Round 3 scope: read-only Gantt per spec §6.4. The editor stays the
// default tab.

import { useMemo, useState } from "react";
import { Button } from "@/components/ui/button";
import type { PersonOption } from "@/components/ui/inline-person-cell";
import type { BadgeTone } from "@/components/ui/status-badge";
import { GanttChart, type GanttRow } from "@/components/ui/gantt-chart";
import { cn } from "@/lib/cn";
import { RENOVATION_TASK_STATUS_TONES } from "@/lib/renovations/constants";
import {
  RenovationTasksEditor,
  type TaskRowVm,
} from "./tasks-editor";

type Props = {
  renovationId: string;
  tasks: TaskRowVm[];
  assigneeOptions: PersonOption[];
  canCreate: boolean;
  canDelete: boolean;
  // Renovation-level planned dates — passed to the Gantt as `extraDates` so
  // the viewport always covers the project scope even when tasks don't
  // reach the edges.
  plannedStartDate: Date | null;
  plannedEndDate: Date | null;
};

type Tab = "list" | "gantt";

export function TasksSection({
  renovationId,
  tasks,
  assigneeOptions,
  canCreate,
  canDelete,
  plannedStartDate,
  plannedEndDate,
}: Props) {
  const [tab, setTab] = useState<Tab>("list");
  const [adding, setAdding] = useState(false);

  const done = tasks.filter((t) => t.status === "done").length;
  const total = tasks.length;
  const pct = total === 0 ? 0 : Math.round((done / total) * 100);

  const ganttRows = useMemo<GanttRow[]>(
    () =>
      tasks.map((t) => ({
        id: t.id,
        label: t.title,
        sublabel: t.assignee?.fullName,
        start: t.startDateIso ? new Date(`${t.startDateIso}T00:00:00Z`) : null,
        end: t.endDateIso ? new Date(`${t.endDateIso}T00:00:00Z`) : null,
        tone: RENOVATION_TASK_STATUS_TONES[t.status] as BadgeTone,
      })),
    [tasks],
  );

  return (
    <section className="bg-neutral-0 rounded-lg p-6 space-y-4">
      <div className="flex items-center justify-between gap-4 flex-wrap">
        <div className="flex items-center gap-3">
          <h2 className="text-md font-medium text-neutral-900">
            Задачи{" "}
            {total > 0 && (
              <span className="text-sm text-neutral-500 font-normal">
                ({done} / {total} завършени · {pct}%)
              </span>
            )}
          </h2>
        </div>
        <div className="flex items-center gap-2">
          <div className="inline-flex rounded-md bg-neutral-100 p-0.5">
            <TabButton current={tab} value="list" onClick={() => setTab("list")}>
              Списък
            </TabButton>
            <TabButton current={tab} value="gantt" onClick={() => setTab("gantt")}>
              Гант
            </TabButton>
          </div>
          {canCreate && tab === "list" && !adding && (
            <Button size="sm" onClick={() => setAdding(true)}>
              + Добави задача
            </Button>
          )}
        </div>
      </div>

      {tab === "list" ? (
        <RenovationTasksEditor
          renovationId={renovationId}
          tasks={tasks}
          assigneeOptions={assigneeOptions}
          canDelete={canDelete}
          adding={adding}
          onCloseAdd={() => setAdding(false)}
        />
      ) : (
        <GanttChart
          rows={ganttRows}
          extraDates={[plannedStartDate, plannedEndDate]}
        />
      )}
    </section>
  );
}

function TabButton({
  current,
  value,
  onClick,
  children,
}: {
  current: Tab;
  value: Tab;
  onClick: () => void;
  children: React.ReactNode;
}) {
  const active = current === value;
  return (
    <button
      type="button"
      onClick={onClick}
      aria-pressed={active}
      className={cn(
        "px-3 py-1 rounded text-sm transition-colors duration-120",
        active
          ? "bg-neutral-0 text-neutral-900 shadow-sm"
          : "text-neutral-600 hover:text-neutral-900",
      )}
    >
      {children}
    </button>
  );
}
</file>

<file path="app/(app)/renovations/actions.ts">
"use server";

import { headers } from "next/headers";
import { revalidatePath } from "next/cache";
import { redirect } from "next/navigation";
import type { Route } from "next";
import type { Prisma, RenovationStatus, RenovationTaskStatus } from "@prisma/client";
import { recordAuditEvent } from "@/lib/auth/audit";
import { requireProfile } from "@/lib/auth/session";
import { prisma } from "@/lib/prisma";
import {
  autoStampDatesFor,
} from "@/lib/renovations/queries";
import {
  isValidRenovationStatus,
  isValidRenovationTaskStatus,
} from "@/lib/renovations/constants";
import {
  parseRenovationFormData,
  type RenovationFormState,
} from "@/lib/renovations/parse";
import {
  canCreateRenovation,
  canDeleteRenovation,
  canEditRenovation,
  canEditRenovationTask,
} from "@/lib/renovations/permissions";

// Server actions for /renovations. Mirrors the contracts/actions.ts shape:
//   - createRenovation + updateRenovation use the useActionState contract
//     (prev state, FormData) → FormState — same as every other module's form
//     actions. Errors land back on the page as field-level messages.
//   - setRenovationStatus is a narrow inline action (transactional with the
//     status-history write).
//   - Task CRUD actions are narrow: addTask / updateTask / setTaskStatus /
//     deleteTask. Round 1 wires the create form for tasks via `addTask`;
//     inline-edit on the detail page lands in Round 2.

const UUID_RE =
  /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

async function logEvent(args: {
  actorId: string;
  action:
    | "renovation.created"
    | "renovation.updated"
    | "renovation.deleted"
    | "renovation.status_changed"
    | "renovation.task.created"
    | "renovation.task.updated"
    | "renovation.task.status_changed"
    | "renovation.task.deleted";
  targetId: string;
  targetType: "renovation" | "renovation_task";
  payload?: Prisma.InputJsonValue;
  before?: Prisma.InputJsonValue;
  after?: Prisma.InputJsonValue;
}): Promise<void> {
  const hdrs = await headers();
  await recordAuditEvent({
    actorId: args.actorId,
    action: args.action,
    targetType: args.targetType,
    targetId: args.targetId,
    payload: args.payload,
    before: args.before,
    after: args.after,
    ip: hdrs.get("x-forwarded-for") ?? null,
    userAgent: hdrs.get("user-agent") ?? null,
  });
}

// ─── Create ───────────────────────────────────────────────────────────────

export async function createRenovation(
  _prev: RenovationFormState,
  formData: FormData,
): Promise<RenovationFormState> {
  const me = await requireProfile();
  if (!canCreateRenovation(me.role)) {
    return { errors: { form: "Нямате достъп до създаването на ремонт." } };
  }
  const parsed = parseRenovationFormData(formData);
  if (!parsed.ok) return { errors: parsed.errors, warnings: parsed.warnings };

  // Verify the property exists (FK is enforced at the DB level but we want
  // a friendlier error than a Prisma constraint violation).
  const property = await prisma.property.findUnique({
    where: { id: parsed.data.propertyId },
    select: { id: true, deletedAt: true },
  });
  if (!property || property.deletedAt !== null) {
    return { errors: { propertyId: "Имотът не съществува." } };
  }

  // managerId defaults to the creator on insert (spec §3.1).
  const managerId = parsed.data.managerId ?? me.id;

  const created = await prisma.$transaction(async (tx) => {
    const r = await tx.renovation.create({
      data: {
        title: parsed.data.title,
        type: parsed.data.type,
        status: parsed.data.status,
        description: parsed.data.description,
        propertyId: parsed.data.propertyId,
        requestedByContactId: parsed.data.requestedByContactId,
        managerId,
        plannedStartDate: parsed.data.plannedStartDate,
        plannedEndDate: parsed.data.plannedEndDate,
        actualStartDate: parsed.data.actualStartDate,
        actualEndDate: parsed.data.actualEndDate,
        createdById: me.id,
      },
    });
    // Seed the status-history with the initial transition (null → status).
    await tx.renovationStatusHistory.create({
      data: {
        renovationId: r.id,
        fromStatus: null,
        toStatus: r.status,
        authorId: me.id,
        note: "Създаване на ремонт",
      },
    });
    return r;
  });

  await logEvent({
    actorId: me.id,
    action: "renovation.created",
    targetType: "renovation",
    targetId: created.id,
    payload: {
      title: created.title,
      propertyId: created.propertyId,
      status: created.status,
      type: created.type,
    },
  });

  revalidatePath("/renovations");
  revalidatePath(`/properties/${parsed.data.propertyId}`);
  if (parsed.data.requestedByContactId) {
    revalidatePath(`/contacts/${parsed.data.requestedByContactId}`);
  }
  return { createdRenovationId: created.id };
}

// ─── Update (full-form edit) ──────────────────────────────────────────────

export async function updateRenovation(
  renovationId: string,
  _prev: RenovationFormState,
  formData: FormData,
): Promise<RenovationFormState> {
  const me = await requireProfile();
  if (!UUID_RE.test(renovationId)) {
    return { errors: { form: "Невалиден ремонт." } };
  }
  const existing = await prisma.renovation.findUnique({
    where: { id: renovationId },
  });
  if (!existing || existing.deletedAt !== null) {
    return { errors: { form: "Ремонтът не е намерен." } };
  }
  if (!canEditRenovation(me.role, existing.managerId, me.id)) {
    return { errors: { form: "Нямате достъп до редактирането на този ремонт." } };
  }

  const parsed = parseRenovationFormData(formData);
  if (!parsed.ok) return { errors: parsed.errors, warnings: parsed.warnings };

  const property = await prisma.property.findUnique({
    where: { id: parsed.data.propertyId },
    select: { id: true, deletedAt: true },
  });
  if (!property || property.deletedAt !== null) {
    return { errors: { propertyId: "Имотът не съществува." } };
  }

  const statusChanged = existing.status !== parsed.data.status;

  const updated = await prisma.$transaction(async (tx) => {
    // If the status is changing, fold in the auto-stamp dates from §3.1
    // BEFORE the user's explicit values — explicit always wins.
    const stamps = statusChanged
      ? autoStampDatesFor(parsed.data.status, {
          actualStartDate: existing.actualStartDate,
          actualEndDate: existing.actualEndDate,
        })
      : {};

    const r = await tx.renovation.update({
      where: { id: renovationId },
      data: {
        title: parsed.data.title,
        type: parsed.data.type,
        status: parsed.data.status,
        description: parsed.data.description,
        propertyId: parsed.data.propertyId,
        requestedByContactId: parsed.data.requestedByContactId,
        managerId: parsed.data.managerId,
        plannedStartDate: parsed.data.plannedStartDate,
        plannedEndDate: parsed.data.plannedEndDate,
        // Explicit user value wins over auto-stamp.
        actualStartDate: parsed.data.actualStartDate ?? stamps.actualStartDate ?? null,
        actualEndDate: parsed.data.actualEndDate ?? stamps.actualEndDate ?? null,
      },
    });
    if (statusChanged) {
      await tx.renovationStatusHistory.create({
        data: {
          renovationId: r.id,
          fromStatus: existing.status,
          toStatus: r.status,
          authorId: me.id,
        },
      });
    }
    return r;
  });

  await logEvent({
    actorId: me.id,
    action: "renovation.updated",
    targetType: "renovation",
    targetId: renovationId,
    before: {
      title: existing.title,
      status: existing.status,
      type: existing.type,
    },
    after: {
      title: updated.title,
      status: updated.status,
      type: updated.type,
    },
  });
  if (statusChanged) {
    await logEvent({
      actorId: me.id,
      action: "renovation.status_changed",
      targetType: "renovation",
      targetId: renovationId,
      payload: { from: existing.status, to: updated.status },
    });
  }

  revalidatePath("/renovations");
  revalidatePath(`/renovations/${renovationId}`);
  revalidatePath(`/properties/${updated.propertyId}`);
  if (updated.requestedByContactId) {
    revalidatePath(`/contacts/${updated.requestedByContactId}`);
  }
  redirect(`/renovations/${renovationId}` as Route);
}

// ─── Soft-delete ──────────────────────────────────────────────────────────

export async function deleteRenovation(formData: FormData): Promise<void> {
  const me = await requireProfile();
  if (!canDeleteRenovation(me.role)) return;
  const id = String(formData.get("renovationId") ?? "");
  if (!UUID_RE.test(id)) return;

  const existing = await prisma.renovation.findUnique({ where: { id } });
  if (!existing || existing.deletedAt !== null) return;

  await prisma.renovation.update({
    where: { id },
    data: { deletedAt: new Date(), deletedById: me.id },
  });

  await logEvent({
    actorId: me.id,
    action: "renovation.deleted",
    targetType: "renovation",
    targetId: id,
    payload: { title: existing.title, propertyId: existing.propertyId },
  });

  revalidatePath("/renovations");
  revalidatePath(`/properties/${existing.propertyId}`);
  if (existing.requestedByContactId) {
    revalidatePath(`/contacts/${existing.requestedByContactId}`);
  }
  redirect("/renovations" as Route);
}

// ─── Status change (inline action) ────────────────────────────────────────

export type SetStatusResult = { ok: true } | { ok: false; error: string };

export async function setRenovationStatus(
  renovationId: string,
  newStatus: RenovationStatus,
): Promise<SetStatusResult> {
  const me = await requireProfile();
  if (!UUID_RE.test(renovationId)) {
    return { ok: false, error: "Невалиден ремонт." };
  }
  if (!isValidRenovationStatus(newStatus)) {
    return { ok: false, error: "Невалиден статус." };
  }
  const existing = await prisma.renovation.findUnique({
    where: { id: renovationId },
    select: {
      id: true,
      status: true,
      managerId: true,
      propertyId: true,
      requestedByContactId: true,
      actualStartDate: true,
      actualEndDate: true,
      deletedAt: true,
    },
  });
  if (!existing || existing.deletedAt !== null) {
    return { ok: false, error: "Ремонтът не е намерен." };
  }
  if (!canEditRenovation(me.role, existing.managerId, me.id)) {
    return { ok: false, error: "Нямате право да променяте този ремонт." };
  }
  if (existing.status === newStatus) return { ok: true };

  const stamps = autoStampDatesFor(newStatus, {
    actualStartDate: existing.actualStartDate,
    actualEndDate: existing.actualEndDate,
  });

  await prisma.$transaction(async (tx) => {
    await tx.renovation.update({
      where: { id: renovationId },
      data: { status: newStatus, ...stamps },
    });
    await tx.renovationStatusHistory.create({
      data: {
        renovationId,
        fromStatus: existing.status,
        toStatus: newStatus,
        authorId: me.id,
      },
    });
  });

  await logEvent({
    actorId: me.id,
    action: "renovation.status_changed",
    targetType: "renovation",
    targetId: renovationId,
    payload: { from: existing.status, to: newStatus },
  });

  revalidatePath("/renovations");
  revalidatePath(`/renovations/${renovationId}`);
  revalidatePath(`/properties/${existing.propertyId}`);
  if (existing.requestedByContactId) {
    revalidatePath(`/contacts/${existing.requestedByContactId}`);
  }
  return { ok: true };
}

// ─── Task CRUD ────────────────────────────────────────────────────────────

export type TaskResult = { ok: true } | { ok: false; error: string };

// Creates a new task at the bottom of the renovation's task list. Used by
// the detail-page "+ Добави задача" affordance.
export async function addRenovationTask(
  renovationId: string,
  formData: FormData,
): Promise<TaskResult> {
  const me = await requireProfile();
  if (!UUID_RE.test(renovationId)) {
    return { ok: false, error: "Невалиден ремонт." };
  }
  const existing = await prisma.renovation.findUnique({
    where: { id: renovationId },
    select: { id: true, managerId: true, deletedAt: true },
  });
  if (!existing || existing.deletedAt !== null) {
    return { ok: false, error: "Ремонтът не е намерен." };
  }
  if (!canEditRenovation(me.role, existing.managerId, me.id)) {
    return { ok: false, error: "Нямате право да редактирате задачите." };
  }

  const title = String(formData.get("title") ?? "").trim();
  if (title.length === 0) return { ok: false, error: "Заглавието е задължително." };
  if (title.length > 200) return { ok: false, error: "Заглавието е твърде дълго (макс. 200)." };

  const description = String(formData.get("description") ?? "").trim() || null;
  const assigneeIdRaw = String(formData.get("assigneeId") ?? "").trim();
  const assigneeId = assigneeIdRaw && UUID_RE.test(assigneeIdRaw) ? assigneeIdRaw : null;
  const startRaw = String(formData.get("startDate") ?? "").trim();
  const endRaw = String(formData.get("endDate") ?? "").trim();
  const startDate = /^\d{4}-\d{2}-\d{2}$/.test(startRaw) ? new Date(`${startRaw}T00:00:00Z`) : null;
  const endDate = /^\d{4}-\d{2}-\d{2}$/.test(endRaw) ? new Date(`${endRaw}T00:00:00Z`) : null;

  // sortOrder = `Date.now()` so newly-added tasks land at the bottom of
  // the existing order. Drag-to-reorder lands in Phase 2.5.
  const created = await prisma.renovationTask.create({
    data: {
      renovationId,
      title,
      description,
      assigneeId: assigneeId ?? existing.managerId,
      startDate,
      endDate,
      sortOrder: BigInt(Date.now()),
      createdById: me.id,
    },
  });

  await logEvent({
    actorId: me.id,
    action: "renovation.task.created",
    targetType: "renovation_task",
    targetId: created.id,
    payload: { renovationId, title },
  });

  revalidatePath(`/renovations/${renovationId}`);
  return { ok: true };
}

export async function setRenovationTaskStatus(
  taskId: string,
  newStatus: RenovationTaskStatus,
): Promise<TaskResult> {
  const me = await requireProfile();
  if (!UUID_RE.test(taskId)) return { ok: false, error: "Невалидна задача." };
  if (!isValidRenovationTaskStatus(newStatus)) {
    return { ok: false, error: "Невалиден статус." };
  }
  const existing = await prisma.renovationTask.findUnique({
    where: { id: taskId },
    include: {
      renovation: {
        select: { id: true, managerId: true, deletedAt: true },
      },
    },
  });
  if (!existing || existing.renovation.deletedAt !== null) {
    return { ok: false, error: "Задачата не е намерена." };
  }
  if (
    !canEditRenovationTask(
      me.role,
      existing.renovation.managerId,
      existing.assigneeId,
      me.id,
    )
  ) {
    return { ok: false, error: "Нямате право да променяте тази задача." };
  }
  if (existing.status === newStatus) return { ok: true };

  await prisma.renovationTask.update({
    where: { id: taskId },
    data: { status: newStatus },
  });

  await logEvent({
    actorId: me.id,
    action: "renovation.task.status_changed",
    targetType: "renovation_task",
    targetId: taskId,
    payload: { from: existing.status, to: newStatus, renovationId: existing.renovationId },
  });

  revalidatePath(`/renovations/${existing.renovationId}`);
  return { ok: true };
}

// ─── Per-field task setters (Round 2 inline editor) ──────────────────────
//
// Each emits a `renovation.task.updated` audit row with `payload: { field }`
// + `before/after: { [field]: value }` — same shape as `contact.field.updated`
// / `tasks.field.updated`. The inline cells on the detail page call these
// directly through their `onSave` props.
//
// All five share the same gate (admin / manager / renovation manager / task
// assignee) and the same target-not-deleted check. Factored into a shared
// guard so each setter stays a thin wrapper.

const ISO_DATE_RE = /^\d{4}-\d{2}-\d{2}$/;

async function loadTaskAndGate(
  taskId: string,
): Promise<
  | {
      ok: true;
      existing: {
        id: string;
        renovationId: string;
        title: string;
        description: string | null;
        assigneeId: string | null;
        startDate: Date | null;
        endDate: Date | null;
        renovation: { managerId: string | null; deletedAt: Date | null };
      };
      actorId: string;
    }
  | { ok: false; error: string }
> {
  const me = await requireProfile();
  if (!UUID_RE.test(taskId)) return { ok: false, error: "Невалидна задача." };
  const existing = await prisma.renovationTask.findUnique({
    where: { id: taskId },
    include: {
      renovation: { select: { managerId: true, deletedAt: true } },
    },
  });
  if (!existing || existing.renovation.deletedAt !== null) {
    return { ok: false, error: "Задачата не е намерена." };
  }
  if (
    !canEditRenovationTask(
      me.role,
      existing.renovation.managerId,
      existing.assigneeId,
      me.id,
    )
  ) {
    return { ok: false, error: "Нямате право да редактирате тази задача." };
  }
  return { ok: true, existing, actorId: me.id };
}

async function logTaskFieldChange(
  actorId: string,
  taskId: string,
  renovationId: string,
  field: string,
  before: unknown,
  after: unknown,
): Promise<void> {
  await logEvent({
    actorId,
    action: "renovation.task.updated",
    targetType: "renovation_task",
    targetId: taskId,
    payload: { field, renovationId } as Prisma.InputJsonValue,
    before: { [field]: (before ?? null) as never } as never,
    after: { [field]: (after ?? null) as never } as never,
  });
}

export async function setRenovationTaskTitle(
  taskId: string,
  newValue: string | null,
): Promise<TaskResult> {
  const gate = await loadTaskAndGate(taskId);
  if (!gate.ok) return gate;
  const trimmed = (newValue ?? "").trim();
  if (trimmed.length === 0) return { ok: false, error: "Заглавието е задължително." };
  if (trimmed.length > 200) {
    return { ok: false, error: "Заглавието е твърде дълго (макс. 200 символа)." };
  }
  if (gate.existing.title === trimmed) return { ok: true };

  await prisma.renovationTask.update({
    where: { id: taskId },
    data: { title: trimmed },
  });
  await logTaskFieldChange(
    gate.actorId,
    taskId,
    gate.existing.renovationId,
    "title",
    gate.existing.title,
    trimmed,
  );

  revalidatePath(`/renovations/${gate.existing.renovationId}`);
  return { ok: true };
}

export async function setRenovationTaskDescription(
  taskId: string,
  newValue: string | null,
): Promise<TaskResult> {
  const gate = await loadTaskAndGate(taskId);
  if (!gate.ok) return gate;
  const trimmed = (newValue ?? "").trim();
  const next = trimmed.length === 0 ? null : trimmed;
  if (next !== null && next.length > 2000) {
    return { ok: false, error: "Описанието е твърде дълго (макс. 2000 символа)." };
  }
  if (gate.existing.description === next) return { ok: true };

  await prisma.renovationTask.update({
    where: { id: taskId },
    data: { description: next },
  });
  await logTaskFieldChange(
    gate.actorId,
    taskId,
    gate.existing.renovationId,
    "description",
    gate.existing.description,
    next,
  );

  revalidatePath(`/renovations/${gate.existing.renovationId}`);
  return { ok: true };
}

export async function setRenovationTaskAssignee(
  taskId: string,
  newAssigneeId: string | null,
): Promise<TaskResult> {
  const gate = await loadTaskAndGate(taskId);
  if (!gate.ok) return gate;
  if (newAssigneeId !== null && !UUID_RE.test(newAssigneeId)) {
    return { ok: false, error: "Невалиден потребител." };
  }
  if (gate.existing.assigneeId === newAssigneeId) return { ok: true };

  // Validate the profile exists (active or not — reassigning to a
  // deactivated person is allowed; we don't auto-clear the FK on deactivation,
  // matching the contact-owner behaviour from contacts.md).
  if (newAssigneeId !== null) {
    const profile = await prisma.profile.findUnique({
      where: { id: newAssigneeId },
      select: { id: true },
    });
    if (!profile) return { ok: false, error: "Потребителят не съществува." };
  }

  await prisma.renovationTask.update({
    where: { id: taskId },
    data: { assigneeId: newAssigneeId },
  });
  await logTaskFieldChange(
    gate.actorId,
    taskId,
    gate.existing.renovationId,
    "assigneeId",
    gate.existing.assigneeId,
    newAssigneeId,
  );

  revalidatePath(`/renovations/${gate.existing.renovationId}`);
  return { ok: true };
}

async function setTaskDateField(
  taskId: string,
  fieldName: "startDate" | "endDate",
  newIso: string | null,
): Promise<TaskResult> {
  const gate = await loadTaskAndGate(taskId);
  if (!gate.ok) return gate;

  let next: Date | null = null;
  if (newIso !== null && newIso.length > 0) {
    if (!ISO_DATE_RE.test(newIso)) {
      return { ok: false, error: "Невалидна дата." };
    }
    next = new Date(`${newIso}T00:00:00Z`);
    if (Number.isNaN(next.getTime())) {
      return { ok: false, error: "Невалидна дата." };
    }
  }

  const beforeIso =
    gate.existing[fieldName] !== null
      ? gate.existing[fieldName]!.toISOString().slice(0, 10)
      : null;
  const nextIso = next ? next.toISOString().slice(0, 10) : null;
  if (beforeIso === nextIso) return { ok: true };

  await prisma.renovationTask.update({
    where: { id: taskId },
    data: { [fieldName]: next },
  });
  await logTaskFieldChange(
    gate.actorId,
    taskId,
    gate.existing.renovationId,
    fieldName,
    beforeIso,
    nextIso,
  );

  revalidatePath(`/renovations/${gate.existing.renovationId}`);
  return { ok: true };
}

export async function setRenovationTaskStartDate(
  taskId: string,
  newIso: string | null,
): Promise<TaskResult> {
  return setTaskDateField(taskId, "startDate", newIso);
}

export async function setRenovationTaskEndDate(
  taskId: string,
  newIso: string | null,
): Promise<TaskResult> {
  return setTaskDateField(taskId, "endDate", newIso);
}

export async function deleteRenovationTask(taskId: string): Promise<TaskResult> {
  const me = await requireProfile();
  if (!UUID_RE.test(taskId)) return { ok: false, error: "Невалидна задача." };
  const existing = await prisma.renovationTask.findUnique({
    where: { id: taskId },
    include: { renovation: { select: { id: true, managerId: true, deletedAt: true } } },
  });
  if (!existing || existing.renovation.deletedAt !== null) {
    return { ok: false, error: "Задачата не е намерена." };
  }
  if (
    !canEditRenovationTask(
      me.role,
      existing.renovation.managerId,
      existing.assigneeId,
      me.id,
    )
  ) {
    return { ok: false, error: "Нямате право да изтриете тази задача." };
  }

  await prisma.renovationTask.delete({ where: { id: taskId } });

  await logEvent({
    actorId: me.id,
    action: "renovation.task.deleted",
    targetType: "renovation_task",
    targetId: taskId,
    payload: { title: existing.title, renovationId: existing.renovationId },
  });

  revalidatePath(`/renovations/${existing.renovationId}`);
  return { ok: true };
}
